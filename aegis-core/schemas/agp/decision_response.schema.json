{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis-initiative.com/schemas/agp/decision_response.schema.json",
  "title": "AGP DECISION_RESPONSE",
  "type": "object",
  "required": ["message_type", "action_id", "decision", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "message_type": { "const": "DECISION_RESPONSE" },
    "action_id": {
      "type": "string",
      "pattern": "^a-[a-zA-Z0-9_-]+$"
    },
    "decision": {
      "$ref": "https://aegis-initiative.com/schemas/common/decision.schema.json"
    },
    "reason": {
      "type": "string"
    },
    "policy_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    }
  }
}
