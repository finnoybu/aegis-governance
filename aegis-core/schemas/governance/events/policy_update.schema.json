{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis-initiative.com/schemas/governance/events/policy_update.schema.json",
  "title": "Policy Update Event",
  "allOf": [
    {
      "$ref": "https://aegis-initiative.com/schemas/governance/governance_event_envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "policy_update" },
        "payload": {
          "type": "object",
          "required": ["policy_id", "version", "authority", "effective_date", "description"],
          "additionalProperties": false,
          "properties": {
            "policy_id": { "type": "string" },
            "version": { "type": "string" },
            "authority": { "type": "string" },
            "effective_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "description": { "type": "string" }
          }
        }
      },
      "required": ["event_type", "payload"]
    }
  ]
}
