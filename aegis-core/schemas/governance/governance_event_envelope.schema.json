{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis-initiative.com/schemas/governance/governance_event_envelope.schema.json",
  "title": "Governance Event Envelope",
  "type": "object",
  "required": ["event_id", "timestamp", "publisher_did", "event_type", "schema_version", "payload", "signature"],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt-[a-zA-Z0-9_-]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "publisher_did": {
      "type": "string",
      "pattern": "^did:aegis:[a-zA-Z0-9._-]+$"
    },
    "event_type": {
      "type": "string",
      "enum": ["policy_update", "circumvention_report", "risk_signal", "governance_attestation", "incident_notice"]
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "payload": {
      "type": "object"
    },
    "signature": {
      "type": "string",
      "minLength": 1
    }
  }
}
