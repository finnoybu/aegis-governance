{
  "_comment": "AEGIS default capability registry — copy to .aegis/registry.json to install",
  "version": "1.6.0",
  "default_posture": "deny",
  "protected_paths": [
    ".aegis/*",
    ".claude/*",
    ".bashrc",
    ".bash_profile",
    ".bash_logout",
    ".profile",
    ".zshrc",
    ".zprofile",
    ".zshenv",
    ".pythonrc.py",
    ".git/hooks/*",
    ".git/config",
    ".gitconfig",
    "Makefile",
    "GNUmakefile",
    "package.json",
    "setup.py",
    ".npmrc",
    ".pypirc",
    "CLAUDE.md",
    ".cursorrules",
    ".github/copilot-instructions.md",
    ".windsurfrules",
    ".continuerc.json",
    ".aider.conf.yml",
    ".envrc",
    "docker-compose.yml",
    ".github/workflows/*"
  ],
  "capabilities": [
    {
      "id": "CAP-001a",
      "name": "shell.read.env",
      "tools": ["Bash"],
      "pattern": "^(env|printenv|set)(\\s|$)",
      "decision": "escalate"
    },
    {
      "id": "CAP-001",
      "name": "shell.read",
      "tools": ["Bash"],
      "pattern": "^(ls|cat|grep|find|echo|pwd|which|head|tail|wc|diff|stat|file|type|where|dir)(\\s|$)",
      "decision": "allow",
      "constraints": {
        "paths_denied": [
          "/proc/*",
          "/dev/*",
          "/var/run/docker.sock",
          "/etc/shadow",
          "/etc/passwd",
          "/etc/hosts",
          "~/.ssh/*",
          "*.key",
          "*.pem",
          "*.p12",
          "*.pfx",
          "*.crt",
          "*.cer",
          "*.der",
          "*.secret",
          "*.credentials",
          ".env",
          ".env.*",
          "*.env",
          ".aegis/*",
          ".claude/*",
          ".git/hooks/*",
          ".bashrc",
          ".bash_profile",
          ".bash_logout",
          ".profile",
          ".zshrc",
          ".zprofile",
          ".zshenv"
        ]
      }
    },
    {
      "id": "CAP-002",
      "name": "shell.build",
      "tools": ["Bash"],
      "pattern": "^(npm|node|npx|yarn|pnpm|git|make|cmake|cargo|go|python|python3|pip|pip3|mvn|gradle|dotnet)(\\s|$)",
      "decision": "escalate"
    },
    {
      "id": "CAP-003",
      "name": "shell.write",
      "tools": ["Bash"],
      "pattern": "^(rm|mv|cp|mkdir|chmod|chown|dd|truncate|tee|install)(\\s|$)",
      "decision": "escalate"
    },
    {
      "id": "CAP-004",
      "name": "shell.network",
      "tools": ["Bash"],
      "pattern": "^(curl|wget|ssh|scp|nc|ncat|nmap|telnet|ftp|sftp)(\\s|$)",
      "decision": "deny"
    },
    {
      "id": "CAP-005a",
      "name": "file.write.exec",
      "tools": ["Write", "Edit"],
      "pattern": "(^|[/\\\\])(package\\.json|setup\\.py|setup\\.cfg|pyproject\\.toml|Makefile|GNUmakefile|Dockerfile|Dockerfile\\..*|docker-compose\\.yml|docker-compose\\..*\\.yml|\\.envrc)$",
      "decision": "escalate"
    },
    {
      "id": "CAP-005b",
      "name": "file.write.config",
      "tools": ["Write", "Edit"],
      "pattern": "(^|[/\\\\])(\\.npmrc|\\.pypirc|\\.cargo/config\\.toml|\\.gitconfig|\\.git/config)$",
      "decision": "escalate"
    },
    {
      "id": "CAP-005ci",
      "name": "file.write.ci",
      "tools": ["Write", "Edit"],
      "pattern": "(^|[/\\\\])\\.github/workflows/.*\\.yml$",
      "decision": "escalate"
    },
    {
      "id": "CAP-005c",
      "name": "file.write.ai-context",
      "tools": ["Write", "Edit"],
      "pattern": "(^|[/\\\\])(CLAUDE\\.md|\\.cursorrules|\\.windsurfrules|\\.continuerc\\.json|\\.aider\\.conf\\.yml|copilot-instructions\\.md|\\.vscode/settings\\.json|\\.vscode/tasks\\.json)$",
      "decision": "escalate"
    },
    {
      "id": "CAP-005",
      "name": "file.write",
      "tools": ["Write", "Edit"],
      "pattern": ".*",
      "decision": "allow",
      "constraints": {
        "paths_denied": [
          ".env",
          ".env.*",
          "*.key",
          "*.pem",
          "*.p12",
          "*.pfx",
          "*.crt",
          "*.cer",
          "*.der",
          "/etc/*",
          "~/.ssh/*",
          "*.secret",
          "*.credentials",
          ".aegis/*",
          ".claude/*",
          ".bashrc",
          ".bash_profile",
          ".bash_logout",
          ".profile",
          ".zshrc",
          ".zprofile",
          ".zshenv",
          ".pythonrc.py",
          ".git/hooks/*"
        ]
      }
    },
    {
      "id": "CAP-006",
      "name": "network.fetch",
      "tools": ["WebFetch"],
      "pattern": ".*",
      "decision": "escalate"
    },
    {
      "id": "CAP-007",
      "name": "computer.action",
      "tools": ["Computer"],
      "pattern": ".*",
      "decision": "escalate"
    }
  ]
}
