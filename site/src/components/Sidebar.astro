---
const pathname = Astro.url.pathname;

const nav = [
  {
    label: 'Foundation',
    slug: 'foundation',
    items: [
      { label: 'Manifesto', slug: 'foundation' },
      { label: 'System Overview', slug: 'foundation/overview' },
      { label: 'FAQ', slug: 'foundation/faq' },
      { label: 'Roadmap', slug: 'foundation/roadmap' },
    ],
  },
  {
    label: 'Architecture',
    slug: 'architecture',
    items: [
      { label: 'Overview', slug: 'architecture' },
      { label: 'Reference Architecture', slug: 'architecture/reference' },
      { label: 'Ecosystem Map', slug: 'architecture/ecosystem-map' },
      { label: 'System Stack', slug: 'architecture/system-stack' },
      { label: 'AI Kernel Model', slug: 'architecture/ai-kernel-model' },
      { label: 'Reference Monitor', slug: 'architecture/reference-monitor' },
      { label: 'Governance Engine', slug: 'architecture/engine-spec' },
      { label: 'Engine Components', slug: 'architecture/engine-components' },
      { label: 'Decision Algorithm', slug: 'architecture/decision-algorithm' },
      { label: 'Request Flow', slug: 'architecture/request-flow' },
      { label: 'Capability Model', slug: 'architecture/capability-model' },
      { label: 'Capability Schema', slug: 'architecture/capability-schema' },
      { label: 'Capability Flow', slug: 'architecture/capability-flow' },
      { label: 'Policy Language', slug: 'architecture/policy-language' },
      { label: 'Policy Matching', slug: 'architecture/policy-matching' },
      { label: 'Risk Scoring Model', slug: 'architecture/risk-model' },
      { label: 'Risk Algorithm', slug: 'architecture/risk-algorithm' },
      { label: 'Trust Boundaries', slug: 'architecture/trust-boundaries' },
      { label: 'Security Assumptions', slug: 'architecture/security-assumptions' },
      { label: 'System Principles', slug: 'architecture/principles' },
    ],
  },
  {
    label: 'Protocol (AGP-1)',
    slug: 'protocol',
    items: [
      { label: 'Specification Index', slug: 'protocol' },
      { label: 'Protocol Overview', slug: 'protocol/overview' },
      { label: 'Authentication', slug: 'protocol/authentication' },
      { label: 'Messages', slug: 'protocol/messages' },
      { label: 'Policy Evaluation', slug: 'protocol/policy-evaluation' },
      { label: 'Risk Scoring', slug: 'protocol/risk-scoring' },
      { label: 'Trust Model', slug: 'protocol/trust-model' },
      { label: 'Wire Format', slug: 'protocol/wire-format' },
    ],
  },
  {
    label: 'Threat Model (ATM/ATX)',
    slug: 'threat-model',
    items: [
      { label: 'ATM-1 Index', slug: 'threat-model' },
      { label: 'Threat Actors', slug: 'threat-model/threat-actors' },
      { label: 'Attack Vectors', slug: 'threat-model/attack-vectors' },
      { label: 'Security Properties', slug: 'threat-model/security-properties' },
      { label: 'Mitigations', slug: 'threat-model/mitigations' },
      { label: 'Residual Risks', slug: 'threat-model/residual-risks' },
      { label: 'ATX-1 Taxonomy', slug: 'threat-model/taxonomy' },
    ],
  },
  {
    label: 'Identity (AIAM-1)',
    slug: 'identity',
    items: [
      { label: 'Specification Index', slug: 'identity' },
      { label: 'Identity Model', slug: 'identity/identity' },
      { label: 'Intent Claims', slug: 'identity/intent' },
      { label: 'Authority (IBAC)', slug: 'identity/authority' },
      { label: 'Capabilities', slug: 'identity/capabilities' },
      { label: 'Delegation', slug: 'identity/delegation' },
      { label: 'Sessions', slug: 'identity/sessions' },
      { label: 'Attestation', slug: 'identity/attestation' },
      { label: 'Revocation', slug: 'identity/revocation' },
      { label: 'Interoperability', slug: 'identity/interoperability' },
      { label: 'Threat Model', slug: 'identity/threat-model' },
      { label: 'Conformance', slug: 'identity/conformance' },
    ],
  },
  {
    label: 'Federation (GFN-1)',
    slug: 'federation',
    items: [
      { label: 'Governance Network', slug: 'federation' },
      { label: 'Trust Model', slug: 'federation/trust-model' },
