---
import Header from '../components/Header.astro';
import Footer from '@aegis-initiative/design-system/components/Footer.astro';

const atxFiles = [
  { name: "STIX 2.1 Bundle", path: "/atx-1/stix-bundle.json", size: "93 KB", desc: "Complete taxonomy — tactics, techniques, mitigations, relationships" },
  { name: "Technique Database", path: "/atx-1/techniques.json", size: "29 KB", desc: "All 29 techniques with severity, case studies, OWASP mapping" },
  { name: "Regulatory Cross-Reference", path: "/atx-1/regulatory-crossref.json", size: "15 KB", desc: "NIST AI RMF, EU AI Act, OWASP LLM Top 10 mapping" },
  { name: "ATM-1 Mapping", path: "/atx-1/atm1-mapping.json", size: "8 KB", desc: "Bidirectional mapping between ATX-1 techniques and MITRE ATT&CK" },
  { name: "ACF-1 Counterfactual Bundle", path: "/atx-1/acf-1-bundle.json", size: "75 KB", desc: "What-if scenarios for technique interactions and governance outcomes" },
  { name: "Technique JSON Schema", path: "/schemas/atx-technique.schema.json", size: "3 KB", desc: "Validation schema for technique definitions" },
  { name: "ATX-1 Index", path: "/atx-1/index.json", size: "2 KB", desc: "Machine-readable index of all ATX-1 artifacts" },
  { name: "ATT&CK Navigator Layer", path: "/atx-1/navigator-layer.json", size: "32 KB", desc: "Load in ATT&CK Navigator via Open Existing Layer → Upload from URL" },
];
---

<!doctype html>
<html lang="en" dir="ltr" data-theme="auto">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AEGIS Governance Data — Machine-Readable Governance Artifacts</title>
  <meta name="description" content="Machine-readable governance artifacts for the AEGIS ecosystem. ATX-1 threat taxonomy, JSON schemas, STIX 2.1 bundles, and regulatory cross-references.">

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="AEGIS Governance Data — Machine-Readable Governance Artifacts" />
  <meta property="og:description" content="ATX-1 threat taxonomy, STIX 2.1 bundles, JSON schemas, and regulatory cross-references for autonomous AI agent governance." />
  <meta property="og:url" content="https://aegis-governance.com" />
  <meta property="og:site_name" content="AEGIS Governance" />
  <meta property="og:image" content="https://aegis-governance.com/OG_image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="AEGIS Governance Data" />
  <meta name="twitter:description" content="Machine-readable governance artifacts for autonomous AI agent governance." />
  <meta name="twitter:image" content="https://aegis-governance.com/OG_image.png" />

  <!-- Machine discovery -->
  <link rel="alternate" type="application/json" href="/.well-known/aegis/manifest.json" title="AEGIS Data Manifest" />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- AEGIS Ecosystem Navigation Bar -->
  <script is:inline src="https://aegis-initiative.com/shared/aegis-nav.js" defer></script>
  <script is:inline>
    document.documentElement.style.setProperty('--aegis-nav-height', '32px');
  </script>

  <link rel="preload" href="/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/poppins-light-webfont.woff2" as="font" type="font/woff2" crossorigin />

  <!-- FOUC prevention -->
  <script is:inline>
    (function () {
      const stored = localStorage.getItem('aegis-theme');
      const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = stored || preferred;
    })();
  </script>

  <!-- Structured Data — Google Dataset Search -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "ATX-1: AEGIS Threat Matrix for Agentic AI Systems",
    "description": "Machine-readable threat taxonomy for autonomous AI agent behavior. 10 tactics, 29 techniques, 29 mitigations in STIX 2.1 and structured JSON. v2.1 adds TA010 (Act Beyond Governance Interpretation).",
    "url": "https://aegis-governance.com",
    "license": "https://www.apache.org/licenses/LICENSE-2.0",
    "creator": {
      "@type": "Organization",
      "name": "AEGIS Initiative",
      "url": "https://aegis-initiative.com"
    },
    "datePublished": "2026-03-26",
    "distribution": [
      {
        "@type": "DataDownload",
        "encodingFormat": "application/json",
        "contentUrl": "https://aegis-governance.com/atx-1/stix-bundle.json"
      },
      {
        "@type": "DataDownload",
        "encodingFormat": "application/json",
        "contentUrl": "https://aegis-governance.com/atx-1/techniques.json"
      },
      {
        "@type": "DataDownload",
        "encodingFormat": "application/json",
        "contentUrl": "https://aegis-governance.com/atx-1/regulatory-crossref.json"
      },
      {
        "@type": "DataDownload",
        "encodingFormat": "application/json",
        "contentUrl": "https://aegis-governance.com/schemas/atx-technique.schema.json"
      },
      {
        "@type": "DataDownload",
        "encodingFormat": "application/json",
        "contentUrl": "https://aegis-governance.com/atx-1/index.json"
      }
    ],
    "citation": {
      "@type": "ScholarlyArticle",
      "name": "AEGIS: A Constitutional Governance Architecture for Autonomous AI Agents",
      "author": {
        "@type": "Person",
        "name": "Kenneth Tannenbaum"
      },
      "url": "https://doi.org/10.5281/zenodo.19223924"
    }
  }
  </script>

  <style>
    /* ── Fonts ─────────────────────────────────────────────────── */

    @font-face {
      font-family: "IBM Plex Sans";
      src: url("/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2") format("woff2");
      font-weight: 100 700;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: "IBM Plex Sans";
      src: url("/fonts/ibmplexsans-italic-variablefont_wdthwght-webfont.woff2") format("woff2");
      font-weight: 100 700;
      font-style: italic;
      font-display: swap;
    }

    @font-face { font-family: "Poppins"; src: url("/fonts/poppins-light-webfont.woff2") format("woff2"); font-weight: 300; font-style: normal; font-display: swap; }
    @font-face { font-family: "Poppins"; src: url("/fonts/poppins-lightitalic-webfont.woff2") format("woff2"); font-weight: 300; font-style: italic; font-display: swap; }
    @font-face { font-family: "Poppins"; src: url("/fonts/poppins-regular-webfont.woff2") format("woff2"); font-weight: 400; font-style: normal; font-display: swap; }
    @font-face { font-family: "Poppins"; src: url("/fonts/poppins-italic-webfont.woff2") format("woff2"); font-weight: 400; font-style: italic; font-display: swap; }
    @font-face { font-family: "Poppins"; src: url("/fonts/poppins-medium-webfont.woff2") format("woff2"); font-weight: 500; font-style: normal; font-display: swap; }
    @font-face { font-family: "Poppins"; src: url("/fonts/poppins-mediumitalic-webfont.woff2") format("woff2"); font-weight: 500; font-style: italic; font-display: swap; }
    @font-face { font-family: "Poppins"; src: url("/fonts/poppins-semibold-webfont.woff2") format("woff2"); font-weight: 600; font-style: normal; font-display: swap; }
    @font-face { font-family: "Poppins"; src: url("/fonts/poppins-semibolditalic-webfont.woff2") format("woff2"); font-weight: 600; font-style: italic; font-display: swap; }

    /* ── Theme tokens ─────────────────────────────────────────── */

    :root, [data-theme="light"] {
      --color-bg: #ffffff;
      --color-bg-subtle: #f5f5f5;
      --color-bg-muted: #eeeeee;
      --color-border: #d4d4d4;
      --color-border-subtle: #e8e8e8;
      --color-text: #161616;
      --color-text-secondary: #595959;
      --color-text-muted: #595959;
      --color-accent: #0062a5;
      --color-accent-low: #e8f4fd;
      --color-brand-gray: #595959;

      --header-bg: #fafafa;
      --header-border: #777777;
      --header-text: #707070;
      --header-text-muted: #707070;

      --card-bg: #f8f8f8;
      --card-bg-hover: #f0f0f0;
      --card-border: #d4d4d4;
      --code-bg: #f5f5f5;
      --green: #006b2d;
      --green-bg: #e9f8ef;
      --orange: #855400;
    }

    [data-theme="dark"] {
      --color-bg: #161616;
      --color-bg-subtle: #1e1e1e;
      --color-bg-muted: #2a2a2a;
      --color-border: #3a3a3a;
      --color-border-subtle: #2a2a2a;
      --color-text: #e8e8e8;
      --color-text-secondary: #b0b0b0;
      --color-text-muted: #888888;
      --color-accent: #4da6f0;
      --color-accent-low: #0d2640;
      --color-brand-gray: #999999;

      --header-bg: #000000;
      --header-border: #000000;
      --header-text: #e8e8e8;
      --header-text-muted: #999999;

      --card-bg: #1e1e1e;
      --card-bg-hover: #2a2a2a;
      --card-border: #3a3a3a;
      --code-bg: #1e1e1e;
      --green: #3fb950;
      --green-bg: #0d2818;
      --orange: #d29922;
    }

    /* ── Reset ─────────────────────────────────────────────────── */

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { font-size: 16px; }

    body {
      font-family: "Poppins", system-ui, sans-serif;
      font-weight: 300;
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.7;
      min-height: 100vh;
    }

    h1, h2, h3 {
      font-family: "IBM Plex Sans", system-ui, sans-serif;
      font-weight: 400;
      line-height: 1.3;
    }

    a { color: var(--color-accent); }

    code {
      font-family: 'JetBrains Mono', 'Cascadia Code', 'Fira Code', monospace;
      font-size: 0.85em;
    }

    /* ── Hero ──────────────────────────────────────────────────── */

    .hero {
      text-align: center;
      padding: 4rem 2rem 2rem;
      max-width: 800px;
      margin: 0 auto;
    }

    .hero h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .hero p {
      font-size: 1.05rem;
      color: var(--color-text-muted);
      max-width: 640px;
      margin: 0 auto 1.5rem;
    }

    .hero-note {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 0.5rem;
      padding: 0.75rem 1.25rem;
      display: inline-block;
      margin-bottom: 2rem;
    }

    .hero-note code { color: var(--color-accent); }

    /* ── Section ───────────────────────────────────────────────── */

    .section {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 2rem 3rem;
    }

    .section h2 {
      font-size: 1.4rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .section-intro {
      color: var(--color-text-muted);
      margin-bottom: 1.5rem;
      font-size: 0.95rem;
    }

    /* ── File list ─────────────────────────────────────────────── */

    .file-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .file-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 0.5rem;
      text-decoration: none;
      color: var(--color-text);
      transition: border-color 0.15s, background-color 0.15s;
    }

    .file-item:hover {
      border-color: var(--color-accent);
      background: var(--card-bg-hover);
    }

    .file-icon {
      font-size: 1.5rem;
      width: 40px;
      text-align: center;
      flex-shrink: 0;
      color: var(--color-text-muted);
    }

    .file-info { flex: 1; }

    .file-name {
      font-family: "IBM Plex Sans", system-ui, sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      margin-bottom: 0.2rem;
    }

    .file-desc {
      font-size: 0.8rem;
      color: var(--color-text-muted);
    }

    .file-meta {
      text-align: right;
      flex-shrink: 0;
    }

    .file-size {
      font-family: monospace;
      font-size: 0.75rem;
      color: var(--color-text-muted);
    }

    .file-format {
      font-family: monospace;
      font-size: 0.7rem;
      color: var(--green);
      background: var(--green-bg);
      padding: 0.1rem 0.4rem;
      border-radius: 0.2rem;
      display: inline-block;
      margin-top: 0.25rem;
    }

    /* ── Code blocks ───────────────────────────────────────────── */

    .code-label {
      font-family: "IBM Plex Sans", system-ui, sans-serif;
      font-size: 0.8rem;
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    .code-block {
      background: var(--code-bg);
      border: 1px solid var(--card-border);
      border-radius: 0.5rem;
      padding: 1.25rem;
      font-family: 'JetBrains Mono', 'Cascadia Code', monospace;
      font-size: 0.8rem;
      line-height: 1.7;
      overflow-x: auto;
      margin-bottom: 1rem;
      color: var(--color-text-muted);
    }

    .code-block .comment { color: var(--color-text-muted); opacity: 0.5; }
    .code-block .cmd { color: var(--green); }
    .code-block .str { color: var(--color-accent); }
    .code-block .kw { color: var(--orange); }

    /* ── Ecosystem grid ────────────────────────────────────────── */

    .ecosystem {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .eco-card {
      display: block;
      padding: 1rem;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 0.5rem;
      text-decoration: none;
      color: var(--color-text);
      transition: border-color 0.15s;
    }

    .eco-card:hover { border-color: var(--color-accent); }

    .eco-card h3 {
      font-size: 0.9rem;
      margin-bottom: 0.3rem;
    }

    .eco-card p {
      font-size: 0.8rem;
      color: var(--color-text-muted);
    }

    /* ── Footer ────────────────────────────────────────────────── */

    .footer {
      border-top: 1px solid var(--color-border);
      padding: 2rem;
      text-align: center;
      color: var(--color-text-muted);
      font-size: 0.8rem;
    }

    .footer a { color: var(--color-accent); text-decoration: none; }
    .footer a:hover { text-decoration: underline; }
    .footer .tagline { font-style: italic; margin-bottom: 0.5rem; }

    /* ── Responsive ────────────────────────────────────────────── */

    @media (max-width: 640px) {
      .hero h1 { font-size: 1.6rem; }
      .file-item { flex-direction: column; align-items: flex-start; }
      .file-meta { text-align: left; }
    }
  </style>
</head>
<body>
  <Header />

  <section class="hero">
    <h1>Governance Data</h1>
    <p>Machine-readable governance artifacts for the AEGIS ecosystem. Structured datasets, schemas, and threat intelligence for automated consumption.</p>
    <div class="hero-note">
      Humans read docs at <code><a href="https://aegis-docs.com" style="text-decoration: none; color: inherit;">aegis-docs.com</a></code> &mdash; machines consume data here.
    </div>
  </section>

  <section class="section">
    <h2>ATX-1 Threat Matrix</h2>
    <p class="section-intro">AEGIS Threat Matrix v2.1 &mdash; 10 tactics, 29 techniques, 29 mitigations. Empirically grounded in the Agents of Chaos study and RFC-0006 adversarial testing. Available in STIX 2.1 and structured JSON.</p>
    <div class="file-list">
      {atxFiles.map((file) => (
        <a href={file.path} class="file-item">
          <div class="file-icon">{"{}"}</div>
          <div class="file-info">
            <div class="file-name">{file.name}</div>
            <div class="file-desc">{file.desc}</div>
          </div>
          <div class="file-meta">
            <div class="file-size">{file.size}</div>
            <div class="file-format">JSON</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Consume</h2>

    <div class="code-label">Fetch the STIX bundle</div>
    <div class="code-block">
      <span class="cmd">curl</span> <span class="str">https://aegis-governance.com/atx-1/stix-bundle.json</span> | <span class="cmd">jq</span> <span class="str">'.objects[] | select(.type == "attack-pattern") | .name'</span>
    </div>

    <div class="code-label">Python &mdash; load techniques</div>
    <div class="code-block">
      <span class="kw">import</span> json, urllib.request<br><br>
      url = <span class="str">"https://aegis-governance.com/atx-1/techniques.json"</span><br>
      techniques = json.loads(urllib.request.urlopen(url).read())<br><br>
      <span class="kw">for</span> t <span class="kw">in</span> techniques:<br>
      &nbsp;&nbsp;&nbsp;&nbsp;print(f"&#123;t['id']&#125;: &#123;t['name']&#125; (&#123;t['severity']&#125;)")
    </div>

    <div class="code-label">Validate against schema</div>
    <div class="code-block">
      <span class="cmd">npx</span> ajv validate <span class="str">-s https://aegis-governance.com/schemas/atx-technique.schema.json</span> <span class="str">-d techniques.json</span>
    </div>
  </section>

  <section class="section">
    <h2>Ecosystem</h2>
    <div class="ecosystem">
      <a href="https://aegis-docs.com" class="eco-card">
        <h3>Documentation</h3>
        <p>Human-readable specs, architecture, API reference, guides</p>
      </a>
      <a href="https://aegis-constitution.com" class="eco-card">
        <h3>Constitution</h3>
        <p>The governance charter &mdash; 11 articles defining AI governance requirements</p>
      </a>
      <a href="https://demo.aegis-platform.net" class="eco-card">
        <h3>Demo API</h3>
        <p>Live governance runtime &mdash; submit proposals, see all four outcomes</p>
      </a>
      <a href="https://aegis-federation.com" class="eco-card">
        <h3>Federation</h3>
        <p>Decentralized governance intelligence sharing via AT Protocol</p>
      </a>
      <a href="https://aegis-initiative.com" class="eco-card">
        <h3>Initiative</h3>
        <p>Organization home &mdash; mission, policy, press</p>
      </a>
      <a href="https://github.com/aegis-initiative/aegis-governance" class="eco-card">
        <h3>Source</h3>
        <p>Governance specs, ATX-1 taxonomy, schemas &mdash; Apache 2.0</p>
      </a>
    </div>
  </section>

  <Footer />
</body>
</html>
