export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id;

// Build breadcrumbs
const parts = slug.split('/');
const section = parts[0];
const sectionLabels: Record<string, string> = {
  foundation: 'Foundation',
  architecture: 'Architecture',
  protocol: 'Protocol (AGP-1)',
  'threat-model': 'Threat Model',
  identity: 'Identity (AIAM-1)',
  federation: 'Federation (GFN-1)',
  rfc: 'RFCs',
};

const breadcrumbs = [];
if (sectionLabels[section]) {
  if (parts.length === 1 || (parts.length === 2 && parts[1] === 'index')) {
    breadcrumbs.push({ label: sectionLabels[section] });
  } else {
    breadcrumbs.push({ label: sectionLabels[section], href: `/${section}/` });
    breadcrumbs.push({ label: entry.data.title });
  }
}

// Compute prev/next
const navIdx = navOrder.findIndex((n) => n.slug === slug);
const prev = navIdx > 0 ? { label: navOrder[navIdx - 1].label, href: `/${navOrder[navIdx - 1].slug}/` } : undefined;
const next = navIdx >= 0 && navIdx < navOrder.length - 1 ? { label: navOrder[navIdx + 1].label, href: `/${navOrder[navIdx + 1].slug}/` } : undefined;
---

<DocLayout title={entry.data.title} description={entry.data.description}>
  {breadcrumbs.length > 0 && <Breadcrumb items={breadcrumbs} slot="breadcrumb" />}
  <Content />
  <PrevNext prev={prev} next={next} />
</DocLayout>
