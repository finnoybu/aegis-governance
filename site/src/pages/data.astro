---
import DocLayout from '../layouts/DocLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const atxFiles = [
  { name: "STIX 2.1 Bundle", path: "/atx-1/stix-bundle.json", size: "147 KB", desc: "Complete taxonomy — tactics, techniques, mitigations, relationships" },
  { name: "Technique Database", path: "/atx-1/techniques.json", size: "68 KB", desc: "All 58 techniques with severity, case studies, OWASP mapping" },
  { name: "Regulatory Cross-Reference", path: "/atx-1/regulatory-crossref.json", size: "50 KB", desc: "NIST AI RMF, EU AI Act, OWASP LLM Top 10 mapping" },
  { name: "ATM-1 Mapping", path: "/atx-1/atm1-mapping.json", size: "10 KB", desc: "Bidirectional mapping between ATX-1 techniques and MITRE ATT&CK" },
  { name: "ACF-1 Counterfactual Bundle", path: "/atx-1/acf-1-bundle.json", size: "75 KB", desc: "What-if scenarios for technique interactions and governance outcomes" },
  { name: "Validation — aegis-core", path: "/atx-1/validation-aegis-core.json", size: "7 KB", desc: "Validation test results against aegis-core runtime" },
  { name: "Version Mapping", path: "/atx-1/version-mapping.json", size: "8 KB", desc: "Version history and technique lifecycle tracking across releases" },
  { name: "Technique JSON Schema", path: "/schemas/atx-technique.schema.json", size: "3 KB", desc: "Validation schema for technique definitions" },
  { name: "ATX-1 Index", path: "/atx-1/index.json", size: "2 KB", desc: "Machine-readable index of all ATX-1 artifacts" },
  { name: "ATT&CK Navigator Layer", path: "/atx-1/navigator-layer.json", size: "67 KB", desc: "Load in ATT&CK Navigator via Open Existing Layer → Upload from URL" },
];
---

<DocLayout title="Data Downloads" description="Machine-readable governance artifacts — ATX-1 threat taxonomy, STIX 2.1 bundles, JSON schemas, and regulatory cross-references.">
  <Breadcrumb items={[{ label: 'Data Downloads' }]} slot="breadcrumb" />

  <h1>Data Downloads</h1>
  <p class="section-intro">Machine-readable governance artifacts for automated consumption. ATX-1 Threat Matrix v2.2 — 10 tactics, 58 techniques in STIX 2.1 and structured JSON.</p>

  <div class="file-list">
    {atxFiles.map((file) => (
      <a href={file.path} class="file-item">
        <div class="file-icon">{"{}"}</div>
        <div class="file-info">
          <div class="file-name">{file.name}</div>
          <div class="file-desc">{file.desc}</div>
        </div>
        <div class="file-meta">
          <div class="file-size">{file.size}</div>
          <div class="file-format">JSON</div>
        </div>
      </a>
    ))}
  </div>

  <h2>Consume</h2>

  <div class="code-label">Fetch the STIX bundle</div>
  <pre><code>curl https://aegis-governance.com/atx-1/stix-bundle.json | jq '.objects[] | select(.type == "attack-pattern") | .name'</code></pre>

  <div class="code-label">Python — load techniques</div>
  <pre><code>import json, urllib.request

url = "https://aegis-governance.com/atx-1/techniques.json"
techniques = json.loads(urllib.request.urlopen(url).read())

for t in techniques:
    print(f"&#123;t['id']&#125;: &#123;t['name']&#125; (&#123;t['severity']&#125;)")</code></pre>

  <div class="code-label">Validate against schema</div>
  <pre><code>npx ajv validate -s https://aegis-governance.com/schemas/atx-technique.schema.json -d techniques.json</code></pre>
</DocLayout>

<style>
  .section-intro {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .file-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .file-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, background-color 0.15s;
  }

  .file-item:hover {
    border-color: var(--color-accent);
    background: var(--color-bg-muted);
  }

  .file-icon {
    font-size: 1.5rem;
    width: 40px;
    text-align: center;
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .file-info { flex: 1; }

  .file-name {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .file-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .file-meta {
    text-align: right;
    flex-shrink: 0;
  }

  .file-size {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .file-format {
    font-family: monospace;
    font-size: 0.7rem;
    color: #006b2d;
    background: #e9f8ef;
    padding: 0.1rem 0.4rem;
    border-radius: 0.2rem;
    display: inline-block;
    margin-top: 0.25rem;
  }

  :global([data-theme="dark"]) .file-format {
    color: #3fb950;
    background: #0d2818;
  }

  .code-label {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .file-item { flex-direction: column; align-items: flex-start; }
    .file-meta { text-align: left; }
  }
</style>
