      "modified": "2026-03-26T00:00:00.000Z",
      "name": "Execution Verification Check",
      "description": "Ensure all reported actions have corresponding execution artifacts.",
      "x_acf_validation_type": "consistency_check",
      "x_acf_required_signals": [
        "execution_log",
        "task_report"
      ],
      "x_acf_expected_condition": "execution_log.exists == true",
      "x_acf_related_atx": [
        "T5001",
        "T5003"
      ]
    },
