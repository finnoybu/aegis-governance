      "modified": "2026-03-26T00:00:00.000Z",
      "name": "Execution / Report Mismatch",
      "description": "Mismatch between reported task completion and actual execution logs.",
      "x_acf_signal_type": "correlation",
      "x_acf_log_source": "agent_execution_layer",
      "x_acf_detection_logic": "reported_success == true AND execution_log.exists == false",
      "x_acf_related_atx": [
        "T5001"
      ]
    },
    {
      "type": "x-acf-validation",
