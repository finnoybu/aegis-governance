      "modified": "2026-03-26T00:00:00.000Z",
      "name": "Tool Chain Anomaly",
      "description": "Detection of unusual sequences of tool invocations forming a potentially unsafe composite action.",
      "x_acf_signal_type": "correlation",
      "x_acf_log_source": "tool_proxy",
      "x_acf_detection_logic": "sequence_length > threshold AND cross_tool_dependency_detected",
      "x_acf_related_atx": [
        "T2004"
      ]
    },
